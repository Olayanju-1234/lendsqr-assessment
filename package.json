  "description": "Demo Credit - Lendsqr Wallet Service MVP",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run migrate && node dist/server.js",
    "dev": "nodemon --exec ts-node src/server.ts",
