    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "joi": "^17.12.0",
    "jsonwebtoken": "^9.0.0",
    "knex": "^3.1.0",
    "morgan": "^1.10.1",
    "mysql2": "^3.9.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.0",
