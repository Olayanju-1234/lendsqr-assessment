{
  "info": {
    "name": "Demo Credit Wallet API",
    "description": "Lendsqr Demo Credit Wallet Service - Complete API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://olayanju-joseph-lendsqr-be-test.up.railway.app"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health & Info",
      "item": [
        {
          "name": "Root",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/",
            "header": []
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/health",
            "header": []
          }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('token', jsonData.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Register (Duplicate - 409)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Register (Missing Fields - 400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"bad@example.com\"\n}"
            }
          }
        },
        {
          "name": "Register Second User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"first_name\": \"Jane\",\n  \"last_name\": \"Doe\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('token', jsonData.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login (Wrong Password - 401)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"wrongpassword\"\n}"
            }
          }
        },
        {
          "name": "Login (Non-existent Email - 401)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nobody@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Wallet Operations",
      "item": [
        {
          "name": "Fund Account",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/wallet/fund",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 5000.00\n}"
            }
          }
        },
        {
          "name": "Fund (Negative Amount - 400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/wallet/fund",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": -100\n}"
            }
          }
        },
        {
          "name": "Fund (Zero Amount - 400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/wallet/fund",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 0\n}"
            }
          }
        },
        {
          "name": "Fund with Idempotency Key",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/wallet/fund",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Idempotency-Key",
                "value": "unique-key-123"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100.00\n}"
            }
          }
        },
        {
          "name": "Transfer to User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/wallet/transfer",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recipient_email\": \"jane@example.com\",\n  \"amount\": 1000.00\n}"
            }
          }
        },
        {
          "name": "Transfer to Self (400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/wallet/transfer",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recipient_email\": \"john@example.com\",\n  \"amount\": 100.00\n}"
            }
          }
        },
        {
          "name": "Transfer to Non-existent User (404)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/wallet/transfer",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recipient_email\": \"ghost@nowhere.com\",\n  \"amount\": 100.00\n}"
            }
          }
        },
        {
          "name": "Transfer Insufficient Funds (400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/wallet/transfer",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recipient_email\": \"jane@example.com\",\n  \"amount\": 99999999.00\n}"
            }
          }
        },
        {
          "name": "Withdraw",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/wallet/withdraw",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 500.00\n}"
            }
          }
        },
        {
          "name": "Withdraw Insufficient Funds (400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/wallet/withdraw",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 99999999.00\n}"
            }
          }
        },
        {
          "name": "Check Balance",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/wallet/balance",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Balance Without Auth (401)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/wallet/balance",
            "header": []
          }
        },
        {
          "name": "Balance With Invalid Token (401)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/wallet/balance",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer invalidtoken123"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Transaction History",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/transactions",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Transaction History (Paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/transactions?page=1&limit=2",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transactions"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "2" }
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Transaction History Page 2",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/transactions?page=2&limit=2",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transactions"],
              "query": [
                { "key": "page", "value": "2" },
                { "key": "limit", "value": "2" }
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    }
  ]
}
